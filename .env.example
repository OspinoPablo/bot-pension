# ====== COPIA ESTE ARCHIVO A ".env" Y LLENA LOS VALORES ======

# Qué IA usar: "gemini" (Google) o "groq". Por defecto: gemini. o openrouter
LLM_PROVIDER=gemini

# --- Si usas OPENROUTER (recomendado) ---
# Saca tu llave gratis en: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modelo gratis (terminan en ":free"). Puedes cambiarlo por otro de openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-oss-120b:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free

# --- Si usas GEMINI (recomendado) ---
# Saca tu llave gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Si usas GROQ (opcional, alternativa) ---
# Saca tu llave gratis en: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tu número personal para recibir AVISOS cuando el bot no sepa responder.
# Formato: código de país + número, SIN +, SIN espacios. Ej Colombia: 573001234567
ADMIN_NUMBER= 573001234567

# Minutos que el bot espera (sin que tú escribas) antes de volver a responder solo
# en un chat donde tú habías entrado manualmente.
AUTO_RESUME_MINUTES=10
